    "import xarray as xr\n",
    "import numpy as np\n",
    "\n",
    "ds = xr.open_dataset(r\"C:\\Users\\imran\\Desktop\\PhD\\roms_data\\roms_climatology_with_river.nc\")\n",
    "print (ds)\n",
    "# Surface layer\n",
    "roms_ssc = ds['silt'].isel(s_rho=-1) * 1000  # mg/L\n",
    "\n",
    "# Interpolate ROMS onto Sentinel sample points\n",
    "df_s2['ROMS_SSC'] = roms_ssc.interp(\n",
    "    lon_rho=xr.DataArray(df_s2['longitude'], dims='points'),\n",
    "    lat_rho=xr.DataArray(df_s2['latitude'], dims='points')\n",
    ").values\n"
   ]
  },
