   "source": [
    "import matplotlib.pyplot as plt\n",
    "from sklearn.metrics import r2_score, mean_squared_error\n",
    "import numpy as np\n",
    "\n",
    "df = df_s2.dropna()\n",
    "\n",
    "r2 = r2_score(df['SSC'], df['ROMS_SSC'])\n",
    "rmse = np.sqrt(mean_squared_error(df['SSC'], df['ROMS_SSC']))\n",
    "\n",
    "plt.figure(figsize=(5,5))\n",
    "plt.scatter(df['SSC'], df['ROMS_SSC'], s=8, alpha=0.5)\n",
    "plt.plot([0,300],[0,300],'k--')\n",
    "plt.xlabel(\"Sentinel-2 SSC (mg/L)\")\n",
    "plt.ylabel(\"ROMS SSC (mg/L)\")\n",
    "plt.title(f\"Sentinel vs ROMS (R²={r2:.2f}, RMSE={rmse:.1f})\")\n",
    "plt.grid()\n",
    "plt.show()\n"
   ]
  },
