   "source": [
    "# --- Sentinel-2 SSC Trend + Labeled Regions ---\n",
    "# ScholarGPT  |  Nechad et al. (2010) SSC model | Northern Bay of Bengal\n",
    "\n",
    "import ee, geemap, sys\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# 🔹 Detect environment\n",
    "is_colab = 'google.colab' in sys.modules\n",
    "if is_colab:\n",
    "    from google.colab import output\n",
    "    output.enable_custom_widget_manager()\n",
    "\n",
    "# Initialize Earth Engine\n",
    "try:\n",
    "    ee.Initialize()\n",
    "except Exception:\n",
    "    ee.Authenticate()\n",
    "    ee.Initialize()\n",
    "\n",
    "# 1️⃣ ROI\n",
    "roi = ee.Geometry.Rectangle([86.0, 20.0, 92.0, 22.5])\n",
    "\n",
    "# 2️⃣ SSC parameters\n",
    "a, c = 289.29, 0.1686\n",
    "\n",
    "def calc_ssc(image):\n",
    "    red = image.select('B4').divide(10000)\n",
    "    ssc = red.expression('a * (B4 / (1 - (B4 / c)))',\n",
    "                         {'B4': red, 'a': a, 'c': c}).rename('SSC')\n",
    "    return image.addBands(ssc)\n",
    "\n",
    "# 3️⃣ Annual composites\n",
    "def yearly_ssc(year):\n",
    "    year = ee.Number(year)\n",
    "    start = ee.Date.fromYMD(year, 1, 1)\n",
    "    end   = start.advance(1, 'year')\n",
    "    img = (ee.ImageCollection('COPERNICUS/S2_SR_HARMONIZED')\n",
    "           .filterBounds(roi)\n",
    "           .filterDate(start, end)\n",
    "           .filter(ee.Filter.lt('CLOUDY_PIXEL_PERCENTAGE', 10))\n",
    "           .map(calc_ssc)\n",
    "           .select('SSC')\n",
    "           .median())\n",
    "    return img.set('year', year)\n",
    "\n",
    "years = ee.List.sequence(2017, 2025)\n",
    "annual = ee.ImageCollection(years.map(yearly_ssc))\n",
    "\n",
    "# 4️⃣ Time band for regression\n",
    "def add_time(image):\n",
    "    y = ee.Number(image.get('year'))\n",
    "    return image.addBands(ee.Image.constant(y).rename('year')).float()\n",
    "\n",
    "annual = annual.map(add_time)\n",
    "\n",
    "# 5️⃣ Linear regression\n",
    "trend = annual.select(['year', 'SSC']).reduce(ee.Reducer.linearFit())\n",
    "trend_img = trend.select('scale').clip(roi)\n",
    "\n",
    "# 6️⃣ Regions\n",
    "regions = {\n",
    "    #\"Antarvedi \": ee.Geometry.Rectangle([81.99, 16.68, 82.6, 17.8]),\n",
    "    #\"Hamsaladeevi \": ee.Geometry.Rectangle([80.92, 15.73, 81.6, 16.8]),\n",
    "    \"Digha Coast\": ee.Geometry.Rectangle([86.8, 21.4, 87.6, 21.8]),\n",
    "    \"Sagar Island\": ee.Geometry.Rectangle([88.0, 21.5, 88.6, 21.9]),\n",
    "    \"Western Sundarbans\": ee.Geometry.Rectangle([88.4, 21.3, 89.2, 21.9]),\n",
    "    \"Meghna Estuary\": ee.Geometry.Rectangle([90.2, 21.2, 91.0, 22.0]),\n",
    "    \"Cox's Bazar\": ee.Geometry.Rectangle([91.0, 21.0, 92.0, 21.7]),\n",
    "}\n",
    "\n",
    "# 7️⃣ Mean SSC trend\n",
    "results = {}\n",
    "for name, geom in regions.items():\n",
    "    mean_val = trend_img.reduceRegion(\n",
    "        reducer=ee.Reducer.mean(), geometry=geom, scale=60, maxPixels=1e9\n",
    "    ).get('scale')\n",
    "    results[name] = mean_val.getInfo()\n",
    "\n",
    "print(\"\\n📊 Mean SSC Trend (mg/L per year):\")\n",
    "for k, v in results.items():\n",
    "    #print(f\"{k}: {v:.3f}\")\n",
    "    print(f\"{k}: {v:.3f}\" if isinstance(v, (int, float)) else f\"{k}: {v}\")\n",
    "\n",
    "\n",
    "# 8️⃣ Plot bar chart\n",
    "plt.figure(figsize=(8,4))\n",
    "plt.bar(results.keys(), results.values(),\n",
    "        color=['royalblue','deepskyblue','gold','orange','red'])\n",
    "plt.axhline(0, color='k', lw=0.8)\n",
    "plt.ylabel(\"Trend (mg/L per year)\")\n",
    "plt.title(\"Mean SSC Trend (2017–2025) – Northern Bay of Bengal\")\n",
    "plt.xticks(rotation=25, ha='right')\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# 9️⃣ Visualization\n",
    "trend_vis = {'min': -10, 'max': 10, 'palette': ['blue', 'white', 'red']}\n",
    "\n",
    "if not is_colab:\n",
    "    Map = geemap.Map(center=[21.5, 89.0], zoom=7)\n",
    "    Map.addLayer(trend_img, trend_vis, 'SSC Trend (mg/L per year)')\n",
    "    for name, geom in regions.items():\n",
    "        Map.addLayer(ee.FeatureCollection([ee.Feature(geom, {'name': name})]),\n",
    "                     {'color': 'black'}, name)\n",
    "        Map.add_text(name, position='topright',\n",
    "                     font_size='12px', text_color='black', outline_color='white')\n",
    "    Map.addLayerControl()\n",
    "    display(Map)\n",
    "else:\n",
    "    url = trend_img.getThumbURL({\n",
    "        'min': -10, 'max': 10, 'palette': ['blue', 'white', 'red'],\n",
    "        'dimensions': 800, 'region': roi\n",
    "    })\n",
    "    print(\"🌐 Static Preview URL:\", url)\n",
    "\n",
    "# 🔟 Export GeoTIFF\n",
    "geemap.ee_export_image(trend_img, filename='Sentinel2_SSC_Trend_2017_2025_BayBengal.tif',\n",
    "                       scale=60, region=roi)\n",
    "print(\"✅ Exported: Sentinel2_SSC_Trend_2017_2025_BayBengal.tif\")\n"
   ]
  },
